{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadInputFolder",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::bis202-yolov5/input/*"
    },
    {
      "Sid": "AllowWriteOutputFolder",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::bis202-yolov5/output/*"
    },
    {
      "Sid": "AllowListBucketForDebugging",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::bis202-yolov5",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "input/*",
            "output/*"
          ]
        }
      }
    }
  ]
}